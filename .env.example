# ── Azure Data Lake Storage Gen2 ─────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT=mystorageaccount
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-service-principal-secret
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── JDBC / SQL Server ─────────────────────────────────────────────────────────
JDBC_HOST=my-sql-server.database.windows.net
JDBC_PORT=1433
JDBC_DATABASE=banking_ops
JDBC_USER=ingestion_svc
JDBC_PASSWORD=your-db-password

# ── REST API Keys ─────────────────────────────────────────────────────────────
API_KEY_OPENEXCHANGERATES=your-openexchangerates-app-id

# Bearer token for account events API
API_BEARER_ACCOUNT_EVENTS=your-bearer-token

# ── Framework settings (optional) ────────────────────────────────────────────
# Local directory for watermark state (overridden to ADLS path in prod)
WATERMARK_STORE_PATH=.watermarks

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ADLS container / filesystem name (default: datalake)
ADLS_FILESYSTEM=datalake
